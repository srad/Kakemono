#!/usr/bin/env bash
# Run any command in the Kakemono dev container. Usage: ./kdev mix phx.server
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
PROJ="$HERE"
MIX_CACHE="${KAKEMONO_CACHE:-$HOME/.cache/kakemono-mix}"
mkdir -p "$MIX_CACHE/hex" "$MIX_CACHE/rebar3" "$MIX_CACHE/mix"
TTY_FLAG="-i"
if [ -t 0 ] && [ -t 1 ]; then TTY_FLAG="-it"; fi
docker run --rm $TTY_FLAG \
  -v "$PROJ":/work -w /work \
  -v "$MIX_CACHE":/cache \
  -u "$(id -u):$(id -g)" \
  -e HOME=/cache \
  -e MIX_HOME=/cache/mix \
  -e HEX_HOME=/cache/hex \
  -e REBAR_CACHE_DIR=/cache/rebar3 \
  -p 4000:4000 \
  kakemono-dev:latest \
  "$@"
